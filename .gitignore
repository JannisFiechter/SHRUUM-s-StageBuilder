
## .gitignore

```gitignore
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Flask
instance/
.webassets-cache

# SQLite databases
*.db
*.sqlite
*.sqlite3

# Local exports
exports/
generated/
pdf_exports/
*.pdf

# Logs
*.log
logs/

# Environment variables
.env
.env.*
!.env.example

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# OS files
Thumbs.db
desktop.ini

# Node / frontend tooling, falls später ergänzt
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Build / dist
build/
dist/
*.egg-info/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.old

# Uploaded/imported local files
uploads/
imports/

# Test artifacts
test_output/
coverage.xml